# =============================
# === User Bash RC Setup =====
# =============================

# If not running interactively, exit early
[[ $- != *i* ]] && return

# -----------------------------
# General Environment Settings
# -----------------------------
export EDITOR=vim
export PAGER=less
export HISTCONTROL=ignoredups:erasedups
export HISTSIZE=10000
export HISTFILESIZE=20000
shopt -s histappend
umask 002

